# App Settings
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=false
APP_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./microsaas.db

# Lemon Squeezy Configuration
# Get your API key from: https://www.lemonsqueezy.com/settings/api-keys
LEMONSQUEEZY_API_KEY=lsq_sk_your_lemonsqueezy_api_key_here

# Store ID from your Lemon Squeezy Dashboard
LEMONSQUEEZY_STORE_ID=your_store_id_here

# Webhook signing secret from: https://www.lemonsqueezy.com/settings/webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Variant IDs for each plan (get from Lemon Squeezy Dashboard > Products > Variants)
# Creator Plan ($12/month) variant ID
LEMONSQUEEZY_VARIANT_ID_CREATOR=your_creator_variant_id

# Pro Plan ($29/month) variant ID
LEMONSQUEEZY_VARIANT_ID_PRO=your_pro_variant_id

# Admin
ADMIN_EMAIL=admin@example.com
